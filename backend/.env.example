# SmartLearnX Backend Environment Variables
# Copy this file to .env and fill in the values

# Port for the Express server to run on
PORT=4000

# MongoDB Atlas or Local Database Connection String
MONGO_URI=mongodb://localhost:27017/lms

# Clerk Auth Keys
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key

# Stripe Payment Secret Key
STRIPE_SECRET_KEY=your_stripe_secret_key

# CORS Settings (comma-separated list of allowed production frontends)
# Example: ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-admin.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Frontend URL (for Stripe success/cancel redirect base)
# Example: FRONTEND_URL=https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:5173
